// PicoClaw Isolated Tool Runtime — Command Protocol
// Namespace: itrfb (FlatBuffers generated types)
//
// This schema defines the binary command protocol between the agent loop
// and the SecureBus. All tool invocations, including RLM recursive
// decomposition operations, are serialized using this schema.
//
// To regenerate: flatc --go -o pkg/itr pkg/itr/commands.fbs
//
// FlatBuffers provides:
//   - Zero-copy reads (no deserialization on the hot path)
//   - Schema-enforced vocabulary (LLM cannot construct out-of-vocab requests)
//   - Single binary format across all transports (channel, socket, WASM)

namespace itrfb;

// ── Command type discriminator ──────────────────────────────────────────────
// Mirrors Go CommandType string constants as a numeric enum for wire encoding.

enum CmdType : byte {
  NONE       = 0,
  Peek       = 1,
  Grep       = 2,
  Partition  = 3,
  Recurse    = 4,
  ToolExec   = 5,
  ExecWasm   = 6,
  Final      = 7,
  ToolSearch = 8,
  CodeExec   = 9,
  DAGPlan    = 10
}

// ── RLM Decomposition Operations ────────────────────────────────────────────

table Peek {
  start:  uint64;
  length: uint32;
}

table Grep {
  pattern:          string (required);
  max_matches:      uint32 = 50;
  case_insensitive: bool   = false;
}

table Partition {
  k:        uint32 = 4;
  method:   string;
  overlap:  uint32 = 0;
  semantic: bool   = false;
}

table Recurse {
  sub_query:   string (required);
  context_key: string (required);
  depth_hint:  uint8  = 3;
}

// ── Traditional Tool Execution ──────────────────────────────────────────────

table ToolExec {
  tool_name: string (required);
  args_json: string (required);
}

table ExecWasm {
  module_key: string (required);
  entry:      string (required);
  input_json: string;
}

table Final {
  answer:   string (required);
  var_name: string;
}

// ── Extended Commands ───────────────────────────────────────────────────────

table ToolSearch {
  query:       string (required);
  max_results: uint8 = 10;
}

table CodeExec {
  language: string (required);
  code:     string (required);
}

// ── Payload Union ───────────────────────────────────────────────────────────
// Used inside both ToolRequest (top-level) and DAGNode (nested).
// DAGPlan is NOT in this union to avoid circular references;
// it is a separate field on ToolRequest.

union CommandPayload {
  Peek,
  Grep,
  Partition,
  Recurse,
  ToolExec,
  ExecWasm,
  Final,
  ToolSearch,
  CodeExec
}

// ── DAG Structures ──────────────────────────────────────────────────────────

table DAGNode {
  id:        string (required);
  node_type: CmdType;
  payload:   CommandPayload;
  depends_on: [string];
}

table DAGPlan {
  nodes:        [DAGNode];
  max_parallel: uint8  = 0;
  token_budget: uint32 = 0;
  joiner_query: string;
}

// ── Envelope ────────────────────────────────────────────────────────────────

table ToolRequest {
  id:           string (required);
  cmd_type:     CmdType;
  payload:      CommandPayload;
  dag_plan:     DAGPlan;
  timestamp:    uint64;
  depth:        uint8  = 0;
  session_key:  string;
  tool_call_id: string;
}

table ToolResponse {
  id:            string (required);
  result:        string;
  is_error:      bool   = false;
  leak_detected: bool   = false;
  cost_tokens:   uint32 = 0;
  redacted_keys: [string];
}

root_type ToolRequest;
