# Runtime reads process environment variables. Docker Compose loads `.env` automatically.
# To use this file locally:
# cp .env.example .env
# set -a; . ./.env; set +a

# ── LLM Provider ──────────────────────────
# Default route below uses OpenRouter. For direct Anthropic, set provider=anthropic
# and model=claude-sonnet-4-20250514 instead.
DRAGONSCALE_AGENTS_DEFAULTS_PROVIDER=openrouter
DRAGONSCALE_AGENTS_DEFAULTS_MODEL=anthropic/claude-sonnet-4-20250514
# DRAGONSCALE_PROVIDERS_OPENROUTER_API_KEY=
# DRAGONSCALE_PROVIDERS_ANTHROPIC_API_KEY=
# DRAGONSCALE_PROVIDERS_OPENAI_API_KEY=
# DRAGONSCALE_PROVIDERS_GEMINI_API_KEY=
# DRAGONSCALE_PROVIDERS_ZHIPU_API_KEY=

# ── Chat Channel ──────────────────────────
# DRAGONSCALE_CHANNELS_TELEGRAM_TOKEN=
# DRAGONSCALE_CHANNELS_DISCORD_TOKEN=
# DRAGONSCALE_CHANNELS_LINE_CHANNEL_SECRET=
# DRAGONSCALE_CHANNELS_LINE_CHANNEL_ACCESS_TOKEN=

# ── Web Search (optional) ────────────────
# DRAGONSCALE_TOOLS_WEB_BRAVE_ENABLED=true
# DRAGONSCALE_TOOLS_WEB_BRAVE_API_KEY=

# ── Timezone ──────────────────────────────
TZ=UTC
